{
  "version": 2,
  "components": {
    "AddToCart": {
      "props": {
        "count": {
          "type": "number",
          "default": 0
        }
      }
    },
    "BottomNav": {
      "props": {
        "activeTab": {
          "type": "enum",
          "values": ["home", "categories", "deals", "profile", "cart"],
          "default": "home"
        },
        "showDeals": {
          "type": "boolean",
          "default": true
        },
        "cartCount": {
          "type": "number",
          "default": 0
        }
      }
    },
    "BottomSheet": {
      "props": {
        "open": {
          "type": "boolean",
          "default": false
        },
        "floating": {
          "type": "boolean",
          "default": false
        },
        "showHandle": {
          "type": "boolean",
          "default": true
        },
        "dismissOnScrimTap": {
          "type": "boolean",
          "default": true
        },
        "ariaLabel": {
          "type": "string"
        }
      }
    },
    "NavBar": {
      "props": {
        "variant": {
          "type": "enum",
          "values": ["solid", "overlay"],
          "default": "solid",
          "class_map": {
            "solid": "nav-bar--solid",
            "overlay": "nav-bar--overlay"
          }
        },
        "title": {
          "type": "string"
        }
      }
    },
    "ProductCardSku": {
      "props": {
        "freeDelivery": {
          "type": "boolean",
          "default": true
        },
        "expressLabel": {
          "type": "string",
          "default": "Today"
        }
      }
    },
    "SkeletonGate": {
      "props": {
        "holdMs": {
          "type": "number",
          "default": 380
        },
        "fadeMs": {
          "type": "number",
          "default": 220
        },
        "ready": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "SmoothCorners": {
      "props": {
        "radius": {
          "type": "number"
        },
        "smoothing": {
          "type": "number",
          "default": 0.6
        }
      }
    },
    "StatusBar": {
      "props": {
        "tone": {
          "type": "enum",
          "values": ["dark", "light"],
          "default": "dark"
        },
        "time": {
          "type": "string",
          "default": "9:41"
        }
      }
    }
  },
